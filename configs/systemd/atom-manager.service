# ATOM System Manager API — systemd service
#
# Install: sudo cp atom-manager.service /etc/systemd/system/
#          sudo systemctl daemon-reload
#          sudo systemctl enable --now atom-manager

[Unit]
Description=ATOM System Manager API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/atom-manager
ExecStart=/opt/atom-manager/venv/bin/uvicorn app:app --host 127.0.0.1 --port 9000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
